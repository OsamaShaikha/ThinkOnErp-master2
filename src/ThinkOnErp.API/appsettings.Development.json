{
  "ConnectionStrings": {
    "Redis": "localhost:6379,abortConnect=false,connectTimeout=5000,syncTimeout=5000"
  },
  "AuditLogging": {
    "BatchSize": 25,
    "BatchWindowMs": 200,
    "MaxQueueSize": 5000,
    "EnableCircuitBreaker": true,
    "EnableFileSystemFallback": true,
    "FallbackDirectory": "AuditFallback",
    "EncryptSensitiveData": false,
    "LogSuccessfulOperations": true
  },
  "AuditIntegrity": {
    "Enabled": false,
    "AutoGenerateHashes": false,
    "VerifyOnRead": false,
    "AlertOnTampering": false
  },
  "RequestTracing": {
    "Enabled": true,
    "LogPayloads": true,
    "PayloadLoggingLevel": "Full",
    "LogRequestStart": true,
    "LogRequestEnd": true,
    "IncludeHeaders": true,
    "LogResponseBody": true
  },
  "PerformanceMonitoring": {
    "Enabled": true,
    "SlowRequestThresholdMs": 500,
    "SlowQueryThresholdMs": 250,
    "TrackMemoryMetrics": true,
    "TrackDatabaseMetrics": true,
    "TrackCpuMetrics": true,
    "MetricsRetentionHours": 12,
    "SlowRequestLogging": {
      "Enabled": true,
      "MaxRecordsPerHour": 200
    },
    "SlowQueryLogging": {
      "Enabled": true,
      "MaxRecordsPerHour": 200,
      "LogQueryParameters": true
    }
  },
  "ComplianceReporting": {
    "Enabled": true,
    "ReportCacheDurationMinutes": 5,
    "EnablePdfGeneration": true,
    "EnableCsvExport": true,
    "EnableJsonExport": true,
    "ScheduledReports": {
      "Enabled": false
    }
  },
  "Archival": {
    "Enabled": false,
    "Schedule": "0 3 * * *",
    "BatchSize": 500,
    "CompressionEnabled": false,
    "VerifyIntegrity": false,
    "RunOnStartup": false,
    "RetentionPolicies": {
      "Authentication": 30,
      "DataChange": 90,
      "Financial": 180,
      "PersonalData": 90,
      "Security": 60,
      "Configuration": 90,
      "Exception": 30,
      "Request": 7
    },
    "ExternalStorage": {
      "Enabled": false
    },
    "CleanupOldArchives": {
      "Enabled": false
    }
  },
  "SecurityMonitoring": {
    "Enabled": true,
    "FailedLoginThreshold": 10,
    "FailedLoginWindowMinutes": 10,
    "AnomalousActivityThreshold": 2000,
    "EnableSqlInjectionDetection": true,
    "EnableXssDetection": true,
    "EnableUnauthorizedAccessDetection": true,
    "EnableAnomalousActivityDetection": false,
    "EnableGeographicAnomalyDetection": false,
    "AutoBlockSuspiciousIps": false,
    "SendEmailAlerts": false,
    "SendWebhookAlerts": false,
    "MaxAlertsPerHour": 50,
    "EnableVerboseLogging": true,
    "UseRedisCache": false
  },
  "AuditQueryCaching": {
    "Enabled": false
  },
  "Alerting": {
    "Enabled": false,
    "MaxAlertsPerRulePerHour": 50,
    "BackgroundProcessing": {
      "Enabled": false
    },
    "Email": {
      "Enabled": false
    },
    "Webhook": {
      "Enabled": false
    },
    "Sms": {
      "Enabled": false
    },
    "AlertRules": {
      "CriticalException": {
        "Enabled": false
      },
      "SecurityThreat": {
        "Enabled": false
      },
      "FailedLoginPattern": {
        "Enabled": false
      },
      "SqlInjectionAttempt": {
        "Enabled": false
      },
      "XssAttempt": {
        "Enabled": false
      },
      "UnauthorizedAccessAttempt": {
        "Enabled": false
      },
      "AnomalousUserActivity": {
        "Enabled": false
      },
      "GeographicAnomaly": {
        "Enabled": false
      },
      "RateLimitExceeded": {
        "Enabled": false
      },
      "PrivilegeEscalationAttempt": {
        "Enabled": false
      },
      "PerformanceDegradation": {
        "Enabled": false
      },
      "HighFailureRate": {
        "Enabled": false
      },
      "ConnectionPoolWarning": {
        "Enabled": false
      },
      "ConnectionPoolCritical": {
        "Enabled": false
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "System": "Information",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {CorrelationId} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/dev-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {CorrelationId} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AuditEncryption": {
    "Enabled": false
  },
  "LegacyAuditService": {
    "Enabled": true
  },
  "AuditQuery": {
    "MaxPageSize": 500,
    "DefaultPageSize": 25,
    "MaxDateRangeDays": 90,
    "QueryTimeoutSeconds": 60,
    "EnableFullTextSearch": false,
    "EnableParallelQueries": false
  },
  "HealthChecks": {
    "Enabled": true,
    "Redis": {
      "Enabled": false
    },
    "ExternalStorage": {
      "Enabled": false
    }
  }
}

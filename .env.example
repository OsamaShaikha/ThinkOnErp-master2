# ThinkOnErp API Environment Variables
# Copy this file to .env and update with your values

# ============================================
# REQUIRED: Oracle Database Connection
# ============================================
# Update with your Oracle database details
# Connection pooling is optimized for high-volume scenarios (10,000+ requests/minute)
ORACLE_CONNECTION_STRING=Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=localhost)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=XEPDB1)));User Id=THINKON_ERP;Password=THINKON_ERP;Pooling=true;Min Pool Size=5;Max Pool Size=100;Connection Timeout=15;Incr Pool Size=5;Decr Pool Size=2;Validate Connection=true;Connection Lifetime=300;Statement Cache Size=50;Statement Cache Purge=false;

# Connection Pooling Parameters Explained:
# - Pooling=true: Enables connection pooling (default: true)
# - Min Pool Size=5: Minimum connections always available (prevents cold starts)
# - Max Pool Size=100: Maximum connections allowed (prevents database overload)
# - Connection Timeout=15: Seconds to wait for connection from pool (fail fast)
# - Incr Pool Size=5: Number of connections to add when pool needs to grow
# - Decr Pool Size=2: Number of connections to remove when pool shrinks
# - Validate Connection=true: Validates connections before use (prevents stale connections)
# - Connection Lifetime=300: Max lifetime in seconds (5 minutes, prevents stale connections)
# - Statement Cache Size=50: Number of prepared statements to cache per connection
# - Statement Cache Purge=false: Keep cached statements across connection reuse

# Example for local Oracle:
# ORACLE_CONNECTION_STRING=Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=192.168.1.100)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=ORCL)));User Id=SYSTEM;Password=YourPassword;Pooling=true;Min Pool Size=5;Max Pool Size=100;Connection Timeout=15;Incr Pool Size=5;Decr Pool Size=2;Validate Connection=true;Connection Lifetime=300;Statement Cache Size=50;Statement Cache Purge=false;

# Example for Oracle Cloud:
# ORACLE_CONNECTION_STRING=Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCPS)(HOST=your-db.oraclecloud.com)(PORT=1522))(CONNECT_DATA=(SERVICE_NAME=your_service)));User Id=ADMIN;Password=YourPassword;Pooling=true;Min Pool Size=5;Max Pool Size=100;Connection Timeout=15;Incr Pool Size=5;Decr Pool Size=2;Validate Connection=true;Connection Lifetime=300;Statement Cache Size=50;Statement Cache Purge=false;

# ============================================
# REQUIRED: JWT Settings
# ============================================
# Generate a secure random key (at least 32 characters)
# You can generate one using: openssl rand -base64 32
JWT_SECRET_KEY=A7fK9xP2LmQ8vR4TzW6nB1CjD5eH3YUs
JWT_ISSUER=ThinkOnErpAPI
JWT_AUDIENCE=ThinkOnErpClient
JWT_EXPIRY_MINUTES=60

# ============================================
# Optional: Application Settings
# ============================================
# Logging level: Debug, Information, Warning, Error
LOG_LEVEL=Information

# API Port (default: 5000)
API_PORT=5000

# ============================================
# Optional: SLA Escalation Settings
# ============================================
# Enable/disable SLA escalation monitoring
SLA_ESCALATION_ENABLED=true

# Hours before SLA deadline to send escalation alerts (default: 2)
SLA_ESCALATION_THRESHOLD_HOURS=2

# Enable/disable background service for automatic SLA monitoring
SLA_ESCALATION_BACKGROUND_SERVICE_ENABLED=true

# Interval in minutes for background service to check SLA compliance (default: 30)
SLA_ESCALATION_BACKGROUND_SERVICE_INTERVAL_MINUTES=30

# ============================================
# Optional: Security Monitoring Settings
# ============================================
# Enable/disable security monitoring
SECURITY_MONITORING_ENABLED=true

# Failed login threshold before flagging as suspicious (default: 5)
SECURITY_FAILED_LOGIN_THRESHOLD=5

# Time window in minutes for tracking failed logins (default: 5)
SECURITY_FAILED_LOGIN_WINDOW_MINUTES=5

# Enable Redis cache for distributed rate limiting (default: false)
# When enabled, provides better performance and distributed tracking across multiple API instances
SECURITY_USE_REDIS_CACHE=false

# Redis connection string (required if SECURITY_USE_REDIS_CACHE=true)
# Format: host:port or host:port,password=yourpassword
REDIS_CONNECTION_STRING=localhost:6379

# Example for Redis with password:
# REDIS_CONNECTION_STRING=localhost:6379,password=yourRedisPassword

# Example for Redis Cloud:
# REDIS_CONNECTION_STRING=redis-12345.c1.us-east-1-2.ec2.cloud.redislabs.com:12345,password=yourPassword

# ============================================
# Optional: Audit Log Integrity Settings
# ============================================
# Enable/disable cryptographic signatures for audit logs (default: true)
AUDIT_INTEGRITY_ENABLED=true

# Base64 encoded signing key for HMAC-SHA256 signatures (REQUIRED if enabled)
# Generate using: dotnet run --project tools/GenerateSigningKey
# Or in C#: Convert.ToBase64String(RandomNumberGenerator.GetBytes(32))
# Or in PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
AUDIT_INTEGRITY_SIGNING_KEY=REPLACE_WITH_BASE64_KEY_GENERATED_USING_RandomNumberGenerator

# Automatically generate integrity hashes for new audit entries (default: true)
AUDIT_INTEGRITY_AUTO_GENERATE_HASHES=true

# Verify integrity on audit log retrieval (default: false)
# WARNING: This adds overhead to read operations
AUDIT_INTEGRITY_VERIFY_ON_READ=false

# Hash algorithm to use: HMACSHA256 or HMACSHA512 (default: HMACSHA256)
AUDIT_INTEGRITY_HASH_ALGORITHM=HMACSHA256

# Trigger alerts when tampering is detected (default: true)
AUDIT_INTEGRITY_ALERT_ON_TAMPERING=true

# ============================================
# Optional: Audit Data Encryption Settings
# ============================================
# Enable/disable encryption of sensitive audit data (default: true)
AUDIT_ENCRYPTION_ENABLED=true

# Base64 encoded encryption key for AES-256-GCM (REQUIRED if enabled)
# Generate using: dotnet run --project src/ThinkOnErp.API -- key-management generate-initial
# Or in C#: Convert.ToBase64String(RandomNumberGenerator.GetBytes(32))
# Or in PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
AUDIT_ENCRYPTION_KEY=REPLACE_WITH_BASE64_KEY_GENERATED_USING_KEY_MANAGEMENT_CLI

# Log encryption operations for debugging (default: false)
AUDIT_ENCRYPTION_LOG_OPERATIONS=false

# ============================================
# Optional: Key Management Settings
# ============================================
# Path to directory where encryption/signing keys are stored
# If not specified, defaults to {AppDirectory}/keys
KEY_MANAGEMENT_STORAGE_PATH=/secure/path/to/keys

# Number of days before keys expire and need rotation (default: 90)
KEY_MANAGEMENT_ROTATION_DAYS=90

# Number of days before expiration to warn about key rotation (default: 7)
KEY_MANAGEMENT_WARNING_DAYS=7

# Enable automatic key rotation when keys expire (default: false)
# When enabled, keys will be rotated automatically by background service
KEY_MANAGEMENT_AUTO_ROTATION=false

# Number of minutes to cache keys in memory before refreshing (default: 60)
KEY_MANAGEMENT_CACHE_REFRESH_MINUTES=60

# Number of days to retain inactive keys before they can be purged (default: 365)
# Inactive keys are needed to decrypt historical data
KEY_MANAGEMENT_INACTIVE_RETENTION_DAYS=365

# Log key management operations (generation, rotation, etc.) (default: true)
KEY_MANAGEMENT_LOG_OPERATIONS=true

# ============================================
# Optional: Twilio SMS Notification Settings
# ============================================
# Enable/disable SMS notifications via Twilio
# Get your credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Sender phone number in E.164 format (e.g., +12025551234)
# Must be a verified Twilio phone number
TWILIO_FROM_PHONE_NUMBER=+12025551234

# Maximum SMS message length (default: 160 characters)
TWILIO_MAX_SMS_LENGTH=160

# Number of retry attempts for failed SMS sends (default: 3)
TWILIO_RETRY_ATTEMPTS=3

# Delay in seconds between retry attempts (default: 5)
TWILIO_RETRY_DELAY_SECONDS=5

# Use exponential backoff for retries (default: true)
TWILIO_USE_EXPONENTIAL_BACKOFF=true
